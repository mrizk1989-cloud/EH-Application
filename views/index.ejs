<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>EH App</title>

    <link rel="stylesheet" href="/css/login.css">

    <!-- Eye + Hint styles -->
    <style>
        .password-wrapper {
            position: relative;
        }

        .toggle-eye {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            font-size: 14px;
            color: #aaa;
            user-select: none;
        }

        .hint {
            font-size: 12px;
            color: #888;
            margin-top: 10px;
            line-height: 1.4;
        }
    </style>
</head>

<body>

<div class="container">

    <div class="box">

        <div class="tabs">
            <button id="loginBtn" type="button">Login</button>
            <button id="registerBtn" type="button">Register</button>
        </div>

        <!-- ================= LOGIN ================= -->
        <form id="loginForm">

            <h2>Login</h2>

            <input type="email" name="email" placeholder="Email" required>

            <div class="password-wrapper">
                <input type="password" name="password" id="loginPassword" placeholder="Password" required>
                <span class="toggle-eye" data-target="loginPassword">👁</span>
            </div>

            <button type="submit">Login</button>

            <p id="msg"></p>
        </form>

        <!-- ================= REGISTER ================= -->
        <form id="registerForm" style="display:none;">

            <h2>Register</h2>

            <input type="text" name="fullName" placeholder="Full Name" required>
            <input type="email" name="email" placeholder="Email" required>

            <div class="password-wrapper">
                <input type="password" name="password" id="registerPassword" placeholder="Password" required>
                <span class="toggle-eye" data-target="registerPassword">👁</span>
            </div>

            <button type="submit">Register</button>

            <p id="msg2"></p>

            <!-- RULES -->
            <div class="hint">
                • Email format: example@email.com<br>
                • Password must include uppercase, lowercase, number (min 8 chars)
            </div>

        </form>

    </div>
</div>

<script src="/js/login.js"></script>
</body>
</html>