<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/css/admin.css">
</head>

<body>

<nav class="navbar">

    <h2>Admin Panel</h2>

    <div class="nav-links">

        <button data-section="users">Users</button>
        <button data-section="requests">Requests</button>

        <!-- SETTINGS DROPDOWN -->
        <div class="dropdown" id="settingsDropdown">

            <button class="dropdown-btn" id="dropdownBtn" type="button">
                Settings ▼
            </button>

            <div class="dropdown-menu" id="dropdownMenu">
                <div class="dropdown-item" data-value="rates">Exchange Rates</div>
                <div class="dropdown-item" data-value="currencies">Currencies</div>
                <div class="dropdown-item" data-value="expenseTypes">Expense Types</div>
            </div>

        </div>

        <button id="logoutBtn">Logout</button>

    </div>

</nav>

<main>

<section id="welcomeSection" class="section active">
    <div class="welcome-box">
        <h1>Welcome Admin 👑</h1>
    </div>
</section>

<section id="usersSection" class="section">
    <h3>Users</h3>
    <table>
        <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Type</th>
            <th>Roles</th>
        </tr>
        </thead>
        <tbody id="usersTableBody"></tbody>
    </table>
</section>

<section id="requestsSection" class="section">
    <h3>Requests</h3>
    <table>
        <thead>
        <tr>
            <th>ID</th>
            <th>Customer</th>
            <th>Amount</th>
            <th>Currency</th>
        </tr>
        </thead>
        <tbody id="requestsTableBody"></tbody>
    </table>
</section>

<section id="settingsSection" class="section">
    <h3 id="settingsTitle">Settings</h3>
    <div id="settingsTableWrapper"></div>
</section>

</main>

<script src="/js/admin.js"></script>

</body>
</html>